# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it should stay out of version control.

# Averer (Eligibility SDK) API key. Obtain from Averer Customer Support:
# https://www.averer.co/
# Leave empty during development — KYC/onboarding API calls will fail until set.
NEXT_PUBLIC_AVERER_API_KEY=""

# Optional: override the default public Redbelly Testnet RPC endpoint.
NEXT_PUBLIC_REDBELLY_TESTNET_RPC_URL=""
