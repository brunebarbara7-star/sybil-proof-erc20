# Safe to commit: this references an env var, it contains no secret itself.
# Set GITHUB_TOKEN locally (shell env) and in Vercel's Environment Variables
# (a GitHub PAT with the `read:packages` scope) so npm can authenticate
# against GitHub Packages to install @redbellynetwork/eligibility-sdk.
@redbellynetwork:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_TOKEN}
always-auth=true